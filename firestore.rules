rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid;
    }

    match /rides/{rideId} {
      allow read: if true;  // drivers browse rides; dashboard reads without auth
      allow create: if request.auth != null
                    && request.resource.data.riderId == request.auth.uid
                    && request.resource.data.status == 'posted';
      allow update: if request.auth != null
                    && !(resource.data.status in ['completed', 'cancelled', 'expired'])
                    && (resource.data.riderId == request.auth.uid
                        || resource.data.driverId == request.auth.uid);
      allow delete: if request.auth.uid == resource.data.riderId
                    && resource.data.status == 'posted';

      match /bids/{bidId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.auth.uid == request.resource.data.driverId;
        allow update: if request.auth != null;
        allow delete: if false;
      }
    }

    match /coinTransactions/{txId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.fromUid
                      || request.auth.uid == resource.data.toUid);
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /reconciliationLogs/{logId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.raterUid;
      allow update, delete: if false;
    }

    // Placeholder profiles for WhatsApp-sourced riders (no Vaahana account yet)
    match /whatsappRiders/{docId} {
      allow read: if true;   // dashboard reads without auth
      allow write: if false; // server-only
    }

    // Ingestion audit trail — dashboard reads without auth
    match /whatsappIngestionLogs/{logId} {
      allow read: if true;   // dashboard reads without auth
      allow write: if false; // server-only
    }
  }
}
